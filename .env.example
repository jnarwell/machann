# Machann Enfòmasyon - Environment Variables
# Copy this file to .env.local and fill in values

# ===========================================
# DATA SOURCES
# ===========================================

# World Bank API (usually doesn't require auth for public data)
# https://datahelpdesk.worldbank.org/knowledgebase/topics/125589
WORLD_BANK_API_KEY=

# Open Exchange Rates (for backup exchange rate data)
# Get free API key at: https://openexchangerates.org/signup/free
OPEN_EXCHANGE_APP_ID=

# ExchangeRate-API (primary exchange rate source)
# Free at: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=

# ===========================================
# ADMIN ACCESS
# ===========================================

# Admin API key for manual data updates
# Generate a secure random string for production
ADMIN_API_KEY=dev-admin-key-change-in-production

# ===========================================
# CACHING (Optional - for production)
# ===========================================

# Vercel KV (if using Vercel's Redis-compatible KV store)
# Automatically available when connected via Vercel dashboard
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Or use external Redis
# REDIS_URL=redis://localhost:6379

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable live data fetching (set to 'false' for demo mode)
NEXT_PUBLIC_ENABLE_LIVE_DATA=true

# Data refresh interval in milliseconds (default: 1 hour)
NEXT_PUBLIC_PRICE_REFRESH_INTERVAL=3600000

# Exchange rate refresh interval (default: 30 min)
NEXT_PUBLIC_EXCHANGE_REFRESH_INTERVAL=1800000

# ===========================================
# ANALYTICS (Optional)
# ===========================================

# Vercel Analytics
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ===========================================
# DEPLOYMENT
# ===========================================

# Base URL for API routes (auto-detected in most cases)
# NEXT_PUBLIC_API_BASE_URL=https://machann.example.com
